# Example environment variables for the Todo API
# Database connection string (update YOUR_PASSWORD)
DATABASE_URL=mssql+aioodbc://sa:YOUR_PASSWORD@localhost:1433/TodoDB?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Logging level (e.g., DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
